{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "stm32-g474re",
            "displayName": "STM32G474RE (EntoBench)",
