            "cacheVariables": {
                "FETCH_ST_SOURCES": "ON",
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "stm32-g474re",
            "configurePreset": "stm32-g474re"
        }
    ]
}
